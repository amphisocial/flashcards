<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Athena Flashcards | AI-driven Quizlets</title>
  <meta name="description" content="AI-driven flashcards and quizlet-style study sets from documents, pasted content, or guided chat." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <div class="shell">
    <header class="topbar">
      <a class="brand" href="#top" aria-label="Athena Flashcards home">
        <span class="brand-mark">A</span>
        <span><strong>Athena</strong> Flashcards</span>
      </a>
      <nav class="nav-links">
        <a href="#create">Create</a>
        <a href="#library">Library</a>
        <a href="#pricing">Pricing</a>
      </nav>
      <div class="auth-area" id="authArea">
        <button class="btn ghost" id="openLogin">Log in</button>
        <button class="btn primary" id="openSignup">Sign up free</button>
      </div>
    </header>

    <main id="top">
      <section class="hero">
        <div class="hero-copy">
          <span class="eyebrow">AI-driven Quizlets for serious learning</span>
          <h1>Turn any document, notes, or study goal into beautiful flashcards.</h1>
          <p>Upload a file, paste content, or use the guided AI coach. Athena builds a clean study set with flip cards, quiz mode, library storage, and invite-based sharing.</p>
          <div class="hero-actions">
            <a href="#create" class="btn primary large">Create study cards</a>
            <a href="#pricing" class="btn soft large">View plans</a>
          </div>
          <div class="trust-row">
            <span>5 free sets/day</span>
            <span>OpenAI or Gemini</span>
            <span>Team sharing</span>
          </div>
        </div>
        <div class="hero-card" aria-hidden="true">
          <div class="floating-card one">
            <span>Interview Prep</span>
            <strong>How do you measure tech ROI?</strong>
          </div>
          <div class="floating-card two">
            <span>SAT Biology</span>
            <strong>Define cellular respiration.</strong>
          </div>
          <div class="study-preview">
            <div class="preview-top">
              <span class="dot"></span><span class="dot"></span><span class="dot"></span>
            </div>
            <p class="mini-label">AI Quizlet Set</p>
            <h3>Exam or Interview Prep</h3>
            <div class="meter"><span style="width:72%"></span></div>
            <p>12 cards generated • mixed quiz + flashcards</p>
          </div>
        </div>
      </section>

      <section class="app-grid" id="create">
        <div class="panel creator-panel">
          <div class="panel-header">
            <div>
              <span class="section-kicker">Create</span>
              <h2>Build a study set</h2>
            </div>
            <span class="usage-pill" id="usagePill">Sign in to track usage</span>
          </div>

          <div class="tabs" role="tablist" aria-label="Source type">
            <button class="tab active" data-tab="paste">Paste content</button>
            <button class="tab" data-tab="upload">Upload document</button>
            <button class="tab" data-tab="chat">Guided chat</button>
          </div>

          <div class="tab-panel active" id="tab-paste">
            <label for="pasteContent">Paste notes, job description, course content, policy text, or any knowledgebase excerpt.</label>
            <textarea id="pasteContent" placeholder="Paste your material here. Example: FinOps principles, a chapter summary, interview notes, SAT topic notes..."></textarea>
          </div>

          <div class="tab-panel" id="tab-upload">
            <label for="docUpload">Upload PDF, DOCX, TXT, Markdown, CSV, or JSON. File size limit is 15MB.</label>
            <div class="upload-box">
              <input id="docUpload" type="file" accept=".pdf,.docx,.txt,.md,.csv,.json" />
              <button class="btn soft" id="extractBtn">Extract text</button>
            </div>
            <textarea id="uploadContent" placeholder="Extracted text will appear here. You can edit it before generating." readonly></textarea>
          </div>

          <div class="tab-panel" id="tab-chat">
            <div class="chat-box" id="chatBox"></div>
            <div class="chat-input-row">
              <input id="chatInput" placeholder="Answer the coach prompt..." />
              <button class="btn primary" id="chatSend">Send</button>
            </div>
            <button class="btn ghost" id="resetChat">Restart guided chat</button>
          </div>

          <div class="control-grid">
            <label>Provider
              <select id="provider">
                <option value="openai">OpenAI</option>
                <option value="gemini">Gemini</option>
              </select>
            </label>
            <label>Cards
              <input id="cardCount" type="number" min="1" max="60" value="10" />
            </label>
            <label>Format
              <select id="format">
                <option value="mixed">Mixed</option>
                <option value="flashcard">Flashcards</option>
                <option value="quiz">Quiz questions</option>
              </select>
            </label>
            <label>Category
              <select id="category">
                <option>Interview preparation</option>
                <option>SAT prep</option>
                <option>GMAT prep</option>
                <option>Grade-level study</option>
                <option>Professional certification</option>
                <option>General learning</option>
              </select>
            </label>
            <label>Grade / level
              <input id="grade" placeholder="e.g., Grade 8, MBA, Executive" />
            </label>
            <label>Subject
              <input id="subject" placeholder="e.g., History, Math, Science" />
            </label>
          </div>

          <label class="wide-label">Extra instructions
            <input id="notes" placeholder="Example: make it CIO interview-ready, include answer choices, keep language simple..." />
          </label>

          <div class="form-actions">
            <button class="btn primary large" id="generateBtn">Generate AI Quizlet</button>
            <span class="status" id="statusText"></span>
          </div>
        </div>

        <div class="panel study-panel">
          <div class="panel-header">
            <div>
              <span class="section-kicker">Study</span>
              <h2 id="setTitle">No set selected</h2>
            </div>
            <span class="card-count" id="cardCounter">0 / 0</span>
          </div>

          <div class="flashcard" id="flashcard" tabindex="0" role="button" aria-label="Flip card">
            <div class="flashcard-inner">
              <div class="card-face card-front">
                <span class="mini-label">Question</span>
                <p id="cardFront">Create or select a study set to begin.</p>
                <div class="choices" id="choices"></div>
              </div>
              <div class="card-face card-back">
                <span class="mini-label">Answer</span>
                <p id="cardBack">The answer will appear here.</p>
                <small id="cardExplanation"></small>
              </div>
            </div>
          </div>

          <div class="study-actions">
            <button class="btn soft" id="prevCard">← Previous</button>
            <button class="btn primary" id="flipCard">Flip</button>
            <button class="btn soft" id="nextCard">Next →</button>
            <button class="btn ghost" id="shuffleCards">Shuffle</button>
          </div>
          <div class="card-list" id="cardList"></div>
        </div>
      </section>

      <section class="panel library-panel" id="library">
        <div class="panel-header">
          <div>
            <span class="section-kicker">Library</span>
            <h2>Your stored Quizlets</h2>
          </div>
          <button class="btn soft" id="refreshLibrary">Refresh</button>
        </div>
        <div class="library-columns">
          <div>
            <h3>Created by you</h3>
            <div class="set-list" id="mySets"></div>
          </div>
          <div>
            <h3>Shared with you</h3>
            <div class="set-list" id="sharedSets"></div>
          </div>
        </div>
      </section>

      <section class="pricing" id="pricing">
        <div class="pricing-heading">
          <span class="section-kicker">Pricing</span>
          <h2>Start free. Upgrade when studying gets serious.</h2>
        </div>
        <div class="pricing-grid">
          <article class="price-card">
            <h3>Free</h3>
            <p class="price">$0</p>
            <p>5 AI Quizlet-style sets per day.</p>
            <button class="btn soft" data-plan="free" disabled>Included</button>
          </article>
          <article class="price-card featured">
            <h3>Starter</h3>
            <p class="price">$3.99<span>/mo</span></p>
            <p>10 study sets per day for students, interview prep, and daily learning.</p>
            <button class="btn primary checkout" data-plan="starter">Upgrade to Starter</button>
          </article>
          <article class="price-card">
            <h3>Teams</h3>
            <p class="price">$9.99<span>/mo</span></p>
            <p>Create and share study sets with up to 30 invited users.</p>
            <button class="btn primary checkout" data-plan="team">Upgrade to Teams</button>
          </article>
        </div>
      </section>
    </main>
  </div>

  <dialog id="authDialog" class="modal">
    <form method="dialog" class="modal-card">
      <button class="modal-close" value="cancel" aria-label="Close">×</button>
      <h2 id="authTitle">Sign up free</h2>
      <div class="two-col auth-names" id="authNames">
        <label>First name<input id="firstName" autocomplete="given-name" /></label>
        <label>Last name<input id="lastName" autocomplete="family-name" /></label>
      </div>
      <label>Email<input id="authEmail" type="email" autocomplete="email" /></label>
      <label>Password<input id="authPassword" type="password" autocomplete="current-password" /></label>
      <button type="button" class="btn primary large" id="authSubmit" value="default">Continue</button>
      <a class="google-link" href="/auth/google">Continue with Google</a>
      <p class="switch-auth" id="switchAuth"></p>
    </form>
  </dialog>

  <dialog id="shareDialog" class="modal">
    <form method="dialog" class="modal-card">
      <button class="modal-close" value="cancel" aria-label="Close">×</button>
      <h2>Share study set</h2>
      <p>Team plan users can invite up to 30 people by email. Invited users can study shared sets for free.</p>
      <label>Email addresses
        <textarea id="shareEmails" placeholder="student1@example.com, student2@example.com"></textarea>
      </label>
      <button type="button" class="btn primary large" id="shareSubmit" value="default">Share</button>
    </form>
  </dialog>

  <template id="setTemplate">
    <button class="set-item">
      <span class="set-title"></span>
      <span class="set-meta"></span>
    </button>
  </template>

  <script src="/app.js?v=20260706-pricing"></script>
</body>
</html>
