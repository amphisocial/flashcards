From 8b11f5820a3d78f879d712eeec55dc6fbae4f944 Mon Sep 17 00:00:00 2001
From: Athena Deploy <deploy@athenabot.ai>
Date: Thu, 9 Jul 2026 14:47:36 +0000
Subject: [PATCH] Add pm2 ecosystem config and dotenv loading for
 pm2/plain-node deploys

---
 deploy/ecosystem.config.js | 25 +++++++++++++++++++++++++
 package-lock.json          | 13 +++++++++++++
 package.json               |  1 +
 server/server.js           |  5 +++++
 4 files changed, 44 insertions(+)
 create mode 100644 deploy/ecosystem.config.js

diff --git a/deploy/ecosystem.config.js b/deploy/ecosystem.config.js
new file mode 100644
index 0000000..e775599
--- /dev/null
+++ b/deploy/ecosystem.config.js
@@ -0,0 +1,25 @@
+// PM2 process definition for Athena Flashcards.
+// Usage: pm2 start deploy/ecosystem.config.js --env production
+module.exports = {
+  apps: [
+    {
+      name: 'flashcards',
+      script: 'server/server.js',
+      cwd: '/opt/apps/flashcards',
+      // .env is loaded by the app itself (make sure server/server.js or its
+      // config module calls require('dotenv').config() — see note below).
+      instances: 1,
+      exec_mode: 'fork',
+      autorestart: true,
+      restart_delay: 3000,
+      max_restarts: 10,
+      watch: false,
+      env: {
+        NODE_ENV: 'production'
+      },
+      error_file: '/opt/apps/flashcards/logs/error.log',
+      out_file: '/opt/apps/flashcards/logs/out.log',
+      time: true
+    }
+  ]
+};
diff --git a/package-lock.json b/package-lock.json
index b501ec3..e4e9faa 100644
--- a/package-lock.json
+++ b/package-lock.json
@@ -9,6 +9,7 @@
       "version": "0.1.0",
       "license": "UNLICENSED",
       "dependencies": {
+        "dotenv": "^17.4.2",
         "express": "^4.19.2",
         "mammoth": "^1.8.0",
         "multer": "^1.4.5-lts.1",
@@ -267,6 +268,18 @@
       "integrity": "sha512-98l0sW87ZT58pU4i61wa2OHwxbiYSbuxsCBozaVnYX2iCnr3bLM3fIes1/ej7h1YdOKuKt/MLs706TVnALA65w==",
       "license": "BSD-2-Clause"
     },
+    "node_modules/dotenv": {
+      "version": "17.4.2",
+      "resolved": "https://registry.npmjs.org/dotenv/-/dotenv-17.4.2.tgz",
+      "integrity": "sha512-nI4U3TottKAcAD9LLud4Cb7b2QztQMUEfHbvhTH09bqXTxnSie8WnjPALV/WMCrJZ6UV/qHJ6L03OqO3LcdYZw==",
+      "license": "BSD-2-Clause",
+      "engines": {
+        "node": ">=12"
+      },
+      "funding": {
+        "url": "https://dotenvx.com"
+      }
+    },
     "node_modules/duck": {
       "version": "0.1.12",
       "resolved": "https://registry.npmjs.org/duck/-/duck-0.1.12.tgz",
diff --git a/package.json b/package.json
index d4d20db..a3065a4 100644
--- a/package.json
+++ b/package.json
@@ -12,6 +12,7 @@
     "node": ">=18"
   },
   "dependencies": {
+    "dotenv": "^17.4.2",
     "express": "^4.19.2",
     "mammoth": "^1.8.0",
     "multer": "^1.4.5-lts.1",
diff --git a/server/server.js b/server/server.js
index b3b4746..de10268 100644
--- a/server/server.js
+++ b/server/server.js
@@ -14,6 +14,11 @@ const pdfParse = require('pdf-parse');
 const mammoth = require('mammoth');
 const Stripe = require('stripe');
 
+// Load .env when present. Under systemd this is redundant (EnvironmentFile=
+// already injects it), but pm2 and plain `node server/server.js` need this
+// to pick up secrets/config from .env.
+require('dotenv').config({ path: path.join(__dirname, '..', '.env') });
+
 const PORT = Number(process.env.PORT || 3004);
 const APP_BASE_URL = (process.env.APP_BASE_URL || `http://localhost:${PORT}`).replace(/\/$/, '');
 const COOKIE_NAME = process.env.SESSION_COOKIE_NAME || 'athena_flashcards_session';
-- 
