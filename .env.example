# ---- Athena Flashcards environment ----
PORT=3004
NODE_ENV=production
APP_BASE_URL=https://flashcards.athenabot.ai
SESSION_COOKIE_NAME=athena_flashcards_session

# Use a long random value in production. Example:
#   openssl rand -hex 32
SESSION_SECRET=change-me-before-production

# ---- AI provider selection ----
# Which provider generates study sets: claude | openai | gemini
# (aliases accepted: anthropic -> claude, google -> gemini)
# If left blank, the first provider below with an API key set is used.
AI_PROVIDER=claude

# ---- LLM provider keys ----
# Only the keys for the provider(s) you use need to be set.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ---- Google OAuth (optional) ----
# Authorized redirect URI:
# https://flashcards.athenabot.ai/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Stripe subscription billing ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=price_replace_with_399_monthly_price_id
STRIPE_PRICE_TEAM=price_replace_with_999_monthly_price_id
