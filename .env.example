# ---- Athena Flashcards environment ----
PORT=3004
NODE_ENV=production
APP_BASE_URL=https://flashcards.athenabot.ai
SESSION_COOKIE_NAME=athena_flashcards_session

# Use a long random value in production. Example:
#   openssl rand -hex 32
SESSION_SECRET=change-me-before-production

# ---- AI provider selection ----
# Which provider generates study sets: claude | openai | gemini
# (aliases accepted: anthropic -> claude, google -> gemini)
# If left blank, the first provider below with an API key set is used.
AI_PROVIDER=claude

# ---- LLM provider keys ----
# Only the keys for the provider(s) you use need to be set.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ---- Slide deck photography (optional) ----
# Set one of these to have "Slides" study sets pull in a real, relevant stock
# photo per slide. Leave both blank to use the built-in gradient/icon slide
# design instead (no external calls made).
# Pexels: https://www.pexels.com/api/  (free, generous limits, no attribution required)
PEXELS_API_KEY=
# Unsplash: https://unsplash.com/developers  (used only if PEXELS_API_KEY is blank)
UNSPLASH_ACCESS_KEY=

# ---- AI generation prompts & "skills" (optional) ----
# The actual prompts sent to the AI live as editable files on the server at
# server/prompts/*.md and server/prompts/skills/*.md — edit them directly,
# no code change or redeploy needed (they're re-read on every generation).
# These two vars pick which skill files get appended, comma-separated:
SLIDE_SKILLS=action-titles,mece-structure,data-viz
CARD_SKILLS=mece-structure
# Your own house style / "secret sauce" instructions always live in
# server/prompts/skills/secret-sauce.md and are appended last (highest
# priority) to every prompt, regardless of the two vars above.

# ---- Google OAuth (optional) ----
# Authorized redirect URI:
# https://flashcards.athenabot.ai/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Stripe subscription billing ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=price_replace_with_399_monthly_price_id
STRIPE_PRICE_TEAM=price_replace_with_999_monthly_price_id

# ---- SMTP (Teams roster invite emails) ----
# Used to email a join link when a teacher invites someone to their Team
# roster. If left blank, invites still work in-app (the roster entry and
# join link are created either way) but no email is sent — the teacher
# would need to copy/send the link manually.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=no-reply@flashcards.athenabot.ai
SMTP_FROM_NAME=Athena Flashcards
